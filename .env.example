# Strataline database connection (used by `loadFrom: "env"` and the db:* scripts)
# Copy to .env and fill in: `cp .env.example .env`
#
# Bun loads .env automatically. On Node.js, add `import 'dotenv/config'` to your
# entrypoint (see scripts/db-migrate.ts).
#
# If you use an envPrefix (e.g. "API_"), prefix every variable below accordingly
# (API_POSTGRES_USER, API_POSTGRES_HOST, ...).

# --- Required ---
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_DATABASE=strataline_dev
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- Optional (defaults shown) ---
# POSTGRES_MAX_CONNECTIONS=20
# POSTGRES_IDLE_TIMEOUT=30000
# POSTGRES_CONNECTION_TIMEOUT=2000
