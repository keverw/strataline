{
  "name": "strataline",
  "version": "3.0.1",
  "type": "module",
  "description": "A structured migration runner for PostgreSQL that treats database changes as layered, resumable operations",
  "exports": {
    "./migration": {
      "types": "./dist/migration/migration.d.ts",
      "import": "./dist/migration/migration.mjs",
      "require": "./dist/migration/migration.js"
    },
    "./test-db-instance": {
      "types": "./dist/test-db-instance/test-db-instance.d.ts",
      "import": "./dist/test-db-instance/test-db-instance.mjs",
      "require": "./dist/test-db-instance/test-db-instance.js"
    },
    "./local-dev-db-server": {
      "types": "./dist/local-dev-db-server/local-dev-db-server.d.ts",
      "import": "./dist/local-dev-db-server/local-dev-db-server.mjs",
      "require": "./dist/local-dev-db-server/local-dev-db-server.js"
    },
    "./cli": {
      "types": "./dist/cli/cli.d.ts",
      "import": "./dist/cli/cli.mjs",
      "require": "./dist/cli/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "bun audit && bun run build && bun run type-check && bun run lint && bun run test",
    "build": "bun run update-readme && tsup",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch",
    "dev:db": "bun run scripts/dev-db.ts",
    "db:migrate": "bun run scripts/db-migrate.ts run",
    "db:migrate:distributed": "bun run scripts/db-migrate.ts run --distributed",
    "db:status": "bun run scripts/db-migrate.ts status",
    "test": "bun test --timeout 60000",
    "test:clean-shm": "bun run scripts/clean-shm.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss,md,html}\"",
    "lint": "eslint src",
    "update-readme": "markdown-toc-gen update README.md && bun run scripts/update-readme-version.ts"
  },
  "keywords": [
    "postgresql",
    "migrations",
    "database",
    "schema",
    "bun"
  ],
  "author": "Kevin Whitman (https://github.com/keverw)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keverw/strataline"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.0",
    "@types/pg": "^8.20.0",
    "@types/tmp": "^0.2.6",
    "eslint": "^10.5.0",
    "markdown-toc-gen": "^1.2.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "peerDependencies": {
    "pg": "^8.21.0"
  },
  "trustedDependencies": [
    "@embedded-postgres/darwin-arm64",
    "@embedded-postgres/darwin-x64",
    "@embedded-postgres/linux-arm",
    "@embedded-postgres/linux-arm64",
    "@embedded-postgres/linux-ia32",
    "@embedded-postgres/linux-ppc64",
    "@embedded-postgres/linux-x64",
    "@embedded-postgres/windows-x64",
    "esbuild"
  ],
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "get-port": "^7.2.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "tmp": "^0.2.7"
  }
}
